# Production / preview builds: set this to your API (e.g. Render).
# Development: `.env.development` defaults to http://localhost:4000 (committed).

VITE_API_BASE_URL=https://your-api.onrender.com

# Must match Backend VAPID_PUBLIC_KEY exactly (from npm run vapid:keys in Backend)
VITE_VAPID_PUBLIC_KEY=
