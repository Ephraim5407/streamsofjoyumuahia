# Used automatically by Vite in development (`pnpm dev`).
# Backend should run with PORT=4000 and HOST=0.0.0.0 (default in this repo).
VITE_API_BASE_URL=http://localhost:4000

# Testing from a phone on the same Wi‑Fi? Copy to `.env.development.local` (gitignored) and set:
# VITE_API_BASE_URL=http://YOUR_LAN_IP:4000
